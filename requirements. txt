import math
import matplotlib.pyplot as plt
import numpy as np

def f(x, expr):
    safe_dict = {
        "builtins": None,
        "x": x,
        "sin": math.sin,
        "cos": math.cos,
        "tan": math.tan,
        "exp": math.exp,
        "log": math.log,
        "sqrt": math.sqrt,
        "pi": math.pi,
        "e": math.e
    }
    return eval(expr, safe_dict)

def derivee(x, expr):
    h = 1e-5
    return (f(x + h, expr) - f(x - h, expr)) / (2 * h)

def dichotomie(expr, a, b, eps, n):
    if f(a, expr) * f(b, expr) > 0:
        return None
    for _ in range(n):
        x = (a + b) / 2
        if abs(f(x, expr)) < eps:
            return x
        if f(a, expr) * f(x, expr) < 0:
            b = x
        else:
            a = x
    return x

def newton(expr, x0, eps, n):
    x = x0
    for _ in range(n):
        d = derivee(x, expr)
        if abs(d) < 1e-10:
            return None
        x_new = x - f(x, expr) / d
        if abs(x_new - x) < eps:
            return x_new
        x = x_new
    return x

def plot_function(expr, root=None):
    x_vals = np.linspace(-10, 10, 400)
    y_vals = []
    for x in x_vals:
        try:
            y_vals.append(f(x, expr))
        except:
            y_vals.append(None)
    plt.figure()
    plt.axhline(0)
    plt.plot(x_vals, y_vals)
    if root is not None:
        plt.scatter(root, f(root, expr))
    plt.title("Graph of f(x)")
    plt.show()

print("حل المعادلة + رسم")

expr = input("ادخل الدالة: ")
eps = float(input("الدقة: "))
n = int(input("عدد التكرارات: "))

a = float(input("a: "))
b = float(input("b: "))
x0 = float(input("x0: "))

sol1 = dichotomie(expr, a, b, eps, n)
sol2 = newton(expr, x0, eps, n)

print("تنصيف:", sol1)
print("نيوتن:", sol2)

solution = sol2 if sol2 is not None else sol1

print("الحل:", solution)

plot_function(expr, solution)
